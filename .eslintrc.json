{
  "env": {
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "eqeqeq": ["error", "always"],
    "strict": ["error", "global"],
    "no-var": ["error"],
    "prefer-const": ["error"],
    "arrow-parens": ["error", "always"],
    "no-console": ["off"],
    "camelcase": ["error"],
    "max-len": ["error", { "code": 80, "ignoreUrls": true }],
    "object-curly-spacing": ["error", "always"],
    "comma-style": ["error", "last"],
    "brace-style": ["error", "1tbs", { "allowSingleLine": true }],
    "space-before-function-paren": ["error", {
      "anonymous": "never",
      "named": "never",
      "asyncArrow": "always"
    }]
  },
  "ignorePatterns": ["frontend/", "node_modules/", "existing-code/"]
}
