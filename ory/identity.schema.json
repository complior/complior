{
  "$id": "https://schemas.aiact.compliance/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Act Compliance Platform - Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "minLength": 6,
          "maxLength": 255,
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              },
              "code": {
                "identifier": true,
                "via": "email"
              }
            },
            "verification": {
              "via": "email"
            },
            "recovery": {
              "via": "email"
            }
          }
        },
        "name": {
          "type": "object",
          "properties": {
            "first": {
              "type": "string",
              "title": "First Name",
              "maxLength": 128
            },
            "last": {
              "type": "string",
              "title": "Last Name",
              "maxLength": 128
            }
          },
          "required": ["first", "last"]
        },
        "organization_id": {
          "type": "integer",
          "title": "Organization ID"
        },
        "locale": {
          "type": "string",
          "title": "Locale",
          "default": "de",
          "enum": ["de", "en"]
        }
      },
      "required": ["email", "name"],
      "additionalProperties": false
    }
  }
}
