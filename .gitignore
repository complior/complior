# AI Act Compliance Platform - .gitignore

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.lcov
.nyc_output

# Production
build/
dist/
.next/
out/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Database
*.db
*.sqlite
*.sqlite3
prisma/migrations/

# Temporary files
tmp/
*.tmp

# BUT: docs/temp/ should be tracked (setup documentation)
!docs/temp/

# OS
Thumbs.db
.DS_Store

# Docker
.dockerignore
docker-compose.override.yml

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# TypeScript cache
*.tsbuildinfo

# Security - DO NOT COMMIT
*.pem
*.key
*.cert
*.p12
*.pfx
.env.*.local
secrets.yml
secrets.json
credentials.json
serviceAccount.json

# API Keys and Tokens
.env.keys
api-keys.txt
tokens.txt

# SSH Keys
id_rsa
id_rsa.pub
*.ppk

# GPG Keys
*.gpg
*.asc

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Kubernetes secrets
k8s/secrets/
*.kubeconfig

# CI/CD
.github/secrets/

# Sentry
.sentryclirc

# Prisma
.env.prisma

# Next.js
.next/
out/
.vercel
.turbo

# Testing
.vitest/
playwright-report/
test-results/

# Package managers
.yarn/
.pnpm-store/
package-lock.json.backup

# OpenClaw specific
.openclaw/sandboxes/
.openclaw/cache/
