# App
PORT=8000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aiact

# Ory Kratos (Identity & Auth)
ORY_SDK_URL=http://localhost:4433
ORY_ADMIN_URL=http://localhost:4434
ORY_WEBHOOK_SECRET=dev-webhook-secret-change-in-production

# Brevo (Transactional Email)
BREVO_API_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587

# Gotenberg (HTML→PDF)
GOTENBERG_URL=http://localhost:3000

# Hetzner S3 (Object Storage)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=compliance-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=fsn1

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_YEARLY=

# Platform Admin
PLATFORM_ADMIN_EMAILS=admin@complior.ai

# Sentry (Error Tracking)
SENTRY_DSN=

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
