# App
PORT=8000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aiact

# WorkOS (Auth)
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
WORKOS_REDIRECT_URI=http://localhost:3001/api/auth/callback
WORKOS_COOKIE_PASSWORD=a-32-char-minimum-secret-for-sealing-sessions

# Brevo (Transactional Email)
BREVO_API_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587

# Gotenberg (HTML→PDF)
GOTENBERG_URL=http://localhost:3000

# Hetzner S3 (Object Storage)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=compliance-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=fsn1

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_YEARLY=

# Platform Admin
PLATFORM_ADMIN_EMAILS=admin@complior.ai
ADMIN_API_TOKEN=

# Sentry (Error Tracking)
SENTRY_DSN=

# Enrichment Pipeline (AI Registry)
OPENROUTER_API_KEY=
ENRICHMENT_LLM_RATE_LIMIT=50
ENRICHMENT_SCAN_RATE=2
ENRICHMENT_SCAN_TIMEOUT=10000
ENRICHMENT_MEDIA_ENABLED=true
ENRICHMENT_PASSIVE_SCAN=true
ENRICHMENT_LLM_TESTS=true
ENRICHMENT_MEDIA_TESTS=true

# Media APIs (optional, for media content testing)
OPENAI_API_KEY=
STABILITY_API_KEY=

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
